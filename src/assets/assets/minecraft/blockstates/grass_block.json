{
    "multipart": [
        {   "when": { "snowy": "false" },
            "apply": { "model": "block/grass_block" }
        },
        {   "when": { "snowy": "false" },
            "apply": [
                { "model": "block/grass_overlay1", "weight": 2 },
                { "model": "block/grass_overlay1", "y": 90, "weight": 2 },
                { "model": "block/grass_overlay1", "y": 180, "weight": 2 },
                { "model": "block/grass_overlay1", "y": 270, "weight": 2 },
                { "model": "block/grass_overlay2", "weight": 1 },
                { "model": "block/grass_overlay2", "y": 90, "weight": 1 },
                { "model": "block/grass_overlay2", "y": 180, "weight": 1 },
                { "model": "block/grass_overlay2", "y": 270, "weight": 1 },
                {"model": "block/air", "weight": 4 }
            ]
        },
        {   "when": { "snowy": "true" },
            "apply": { "model": "block/grass_block_snow" }
        }
    ]
}
